# =============================================================================
# CloudBase 配置（私募基金看板数据库）
# =============================================================================
# CloudBase 环境 ID，在腾讯云开发控制台 → 环境 → 环境总览中获取
CLOUDBASE_ENV_ID=your-cloudbase-env-id

# 可选：公开的环境 ID（用于前端直接调用时，如无需要可与 CLOUDBASE_ENV_ID 相同）
NEXT_PUBLIC_CLOUDBASE_ENV_ID=your-cloudbase-env-id

# =============================================================================
# 飞书 Bitable 配置（保留，用于飞书数据同步功能）
# =============================================================================
# 飞书应用的 App ID 和 App Secret
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret

# 私募基金 Bitable 的 app_token 和 table_id
# app_token：从飞书多维表格 URL /base/XXX 中获取
# table_id：从飞书多维表格 URL ?table=YYY 中获取
FEISHU_PRIVATE_FUND_APP_TOKEN=your-feishu-private-fund-app-token
FEISHU_TABLE_PRIVATE_FUND_INPUT=your-feishu-table-private-fund-input

# =============================================================================
# Render 部署说明
# =============================================================================
# 在 Render Dashboard → Environment 中添加以上环境变量。
# 注意：CloudBase 环境 ID 是必填项，缺少时将自动降级到本地静态数据。
