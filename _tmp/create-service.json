{
  "type": "web_service",
  "name": "jucai-tonglu",
  "repo": "https://github.com/WYH509/jucai-tonglu",
  "branch": "main",
  "rootDir": ".",
  "ownerId": "tea-d7uldndckfvc73bbr05g",
  "autoDeploy": "yes",
  "serviceDetails": {
    "env": "node",
    "plan": "starter",
    "runtime": "node",
    "region": "oregon",
    "numInstances": 1,
    "buildPlan": "starter",
    "healthCheckPath": "/",
    "openPorts": [{"protocol": "HTTP", "port": 3000}],
    "url": "https://jucai-tonglu.onrender.com",
    "pullRequestPreviewsEnabled": "no",
    "envSpecificDetails": {
      "nodeVersion": "20",
      "buildCommand": "npm install && npm run build",
      "startCommand": "npm run start"
    }
  },
  "envVars": [{"key": "NODE_VERSION", "value": "20"}]
}
